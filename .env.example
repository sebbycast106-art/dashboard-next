# ─────────────────────────────────────────────
# DASHBOARD-NEXT — Environment Variables
# Copy this file to .env.local and fill in values
# Never commit .env.local to git
#
# WHY THIS EXISTS: When you clone this repo fresh or someone new joins, they
# know exactly what to set up. No more "why is production different from local?"
# ─────────────────────────────────────────────


# ── Auth ──────────────────────────────────────────────────────────────────────

# [REQUIRED] Bcrypt hash of the dashboard login password
# Generate: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',12))"
DASHBOARD_PASSWORD_HASH=your_bcrypt_hash_here

# [REQUIRED] Secret key used to sign JWT session tokens (random 64-char hex)
# Generate: openssl rand -hex 32
JWT_SECRET=your_64_char_hex_here

# [REQUIRED] Secret used to authenticate push requests from bots to /api/automations/push
# Should match the SCHEDULER_SECRET set in each bot's environment (Railway, etc.)
# Generate: openssl rand -hex 32
SCHEDULER_SECRET=your_scheduler_secret_here


# ── Database ──────────────────────────────────────────────────────────────────

# [OPTIONAL] Prisma database connection URL
# Defaults to a local SQLite file (file:./dashboard.db) if not set
# For PostgreSQL: postgresql://user:password@host:5432/dbname
# For SQLite:     file:./dashboard.db
DATABASE_URL=postgresql://user:password@localhost:5432/dashboard


# ── LinkedIn Bot ──────────────────────────────────────────────────────────────

# [OPTIONAL] Base URL of the deployed LinkedIn bot service
# Defaults to the Railway production URL if not set
LINKEDIN_BOT_URL=https://linkedin-bot-production-c351.up.railway.app

# [OPTIONAL] Shared secret for authenticating requests to the LinkedIn bot
# Must match SCHEDULER_SECRET set in the linkedin-bot environment
# Leave empty if the bot has no auth requirement (not recommended for production)
LINKEDIN_BOT_SECRET=your_linkedin_bot_secret_here


# ── Assistant Bot ─────────────────────────────────────────────────────────────

# [OPTIONAL] Base URL of the deployed personal assistant bot service
# Defaults to the Railway production URL if not set
ASSISTANT_BOT_URL=https://web-production-xxxxxx.up.railway.app

# [OPTIONAL] Shared secret for authenticating requests to the assistant bot
# Leave empty if the bot has no auth requirement
ASSISTANT_BOT_SECRET=your_assistant_bot_secret_here
